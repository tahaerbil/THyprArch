{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 8,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    
    // Merkez bankasından modülleri dahil et
    "include": ["~/.config/waybar/modules.jsonc"],

    "modules-left": ["custom/power", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock#calendar"],
    "modules-right": ["tray", "backlight", "pulseaudio", "network", "battery"]
}
