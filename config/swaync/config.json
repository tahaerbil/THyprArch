{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 12,
  "control-center-margin-bottom": 12,
  "control-center-margin-right": 12,
  "control-center-margin-left": 12,
  "notification-2way-close": true,
  "notification-drop-shadow": false,
  "labels": "system",
  "image-visibility": "when-available",
  "transition-length": 250,
  "keyboard-shortcuts": true,
  "invoke-action-on-action": true,
  "search-action": "none",
  "notification-window-width": 360,
  "keyboard-shortcuts-action": "close",
  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 400,
  "control-center-height": 700,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Bildirim Merkezi",
      "clear-all-button": true,
      "button-text": "Hepsini Temizle"
    },
    "dnd": {
      "text": "Rahatsız Etme"
    },
    "mpris": {
      "image-size": 72,
      "image-radius": 10
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃠"
    }
  }
}
